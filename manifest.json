{
  "manifest_version": 3,
  "name": "Dark Mode",
  "version": "1.0",
  "description": "Toggle dark mode on any page with one click.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "permissions": ["activeTab", "scripting"]
}
